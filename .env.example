# ──────────────────────────────────────────────────────────────────────────────
# Garuda v2 — Jaipur Intelligence Platform — Environment Variables
# Copy this file to .env and fill in all values.
# ──────────────────────────────────────────────────────────────────────────────

# ── AstraDB ───────────────────────────────────────────────────────────────────
# Create a free Serverless (Vector) database at https://astra.datastax.com
# Region: ap-south-1 (Mumbai) for lowest latency from Jaipur
ASTRA_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASTRA_DB_REGION=ap-south-1
ASTRA_DB_KEYSPACE=garuda
ASTRA_DB_APPLICATION_TOKEN=AstraCS:...

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIM=768

# ── LLM Backends ─────────────────────────────────────────────────────────────
# Gemini (primary): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (NLP fallback): https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Pipeline ──────────────────────────────────────────────────────────────────
SCRAPE_INTERVAL_MINUTES=15
MAX_ARTICLES_PER_SOURCE=8
ARTICLE_PROCESS_DELAY_SECONDS=6.0
GEMINI_MIN_INTERVAL_SECONDS=5.0
GROQ_MIN_INTERVAL_SECONDS=2.5

# Optional: protect POST /scrape with a shared key
# SCRAPE_API_KEY=your_secret_here
# VITE_SCRAPE_API_KEY=your_secret_here   # must match for the UI scrape button

# ── Analysis Jobs ─────────────────────────────────────────────────────────────
TREND_DETECTION_INTERVAL_HOURS=6
ANOMALY_DETECTION_INTERVAL_HOURS=4
BRIEF_GENERATION_TIME_IST=07:00
SEMANTIC_DEDUP_THRESHOLD=0.92
ENTITY_RESOLUTION_THRESHOLD=0.88
TREND_SPIKE_RATIO=2.0

# ── Legacy (keep during dual-write; remove after Phase 6) ────────────────────
# DB_PATH=jip.db
# DUAL_WRITE_ENABLED=true
